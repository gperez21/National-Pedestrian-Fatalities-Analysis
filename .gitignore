# Raw FARS data downloads (re-downloadable from NHTSA)
data/raw/*
!data/raw/.gitkeep

# Processed images (regenerated by running notebooks)
data/processed/*.png
data/processed/*.jpg
data/processed/*.svg

# Parquet / cache files (regenerated on first run)
data/processed/*.parquet

# Python virtual environment
.venv/
venv/
env/

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Jupyter checkpoints
.ipynb_checkpoints/

# macOS
.DS_Store
**/.DS_Store

# Editor
.vscode/
.idea/

# Distribution / build
dist/
build/
*.egg-info/

# HTML exports
pdfs/*.html
